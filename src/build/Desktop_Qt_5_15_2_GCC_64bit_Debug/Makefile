qmake: FORCE
	@$(QMAKE) -o Makefile ../../raspi-turntable.pro -spec linux-g++ CONFIG+=debug CONFIG+=qml_debug

qmake_all: FORCE


all: Makefile raspi-turntable

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../resources/resources.qrc $(DISTDIR)/
	$(COPY_FILE) --parents /home/dani/Qt/5.15.2/gcc_64/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../mainwindow.h ../../turntableclient.h ../../widgetturntable.h $(DISTDIR)/
	$(COPY_FILE) --parents ../../main.cpp ../../mainwindow.cpp ../../turntableclient.cpp ../../widgetturntable.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../mainwindow.ui $(DISTDIR)/


